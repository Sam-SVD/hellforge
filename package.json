<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no"/>
  <title>Hellforge 8 Multiplayer Arena</title>
  <style>
    * { box-sizing: border-box; }
    html, body {
      margin: 0;
      height: 100%;
      overflow: hidden;
      background: #07070a;
      color: #ffe8c7;
      font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      user-select: none;
    }
    body { display: grid; place-items: center; }
    .frame { width: min(100vw, 1120px); height: min(100vh, 760px); position: relative; padding: 10px; }
    canvas {
      width: 100%;
      height: 100%;
      display: block;
      background: #000;
      border: 4px solid #28202a;
      image-rendering: pixelated;
      box-shadow: 0 20px 70px rgba(0,0,0,.65);
    }
    .overlay {
      position: absolute;
      inset: 10px;
      display: grid;
      place-items: center;
      pointer-events: none;
    }
    .panel {
      width: min(620px, calc(100% - 24px));
      pointer-events: auto;
      background: rgba(11, 9, 14, .92);
      border: 3px solid #7d2636;
      box-shadow: 0 0 0 3px rgba(255, 200, 99, .12), 0 28px 80px rgba(0,0,0,.72);
      padding: 22px;
      text-align: center;
    }
    h1 {
      margin: 0 0 8px;
      font-size: clamp(32px, 7vw, 62px);
      color: #ffcc5c;
      text-shadow: 4px 4px 0 #6b1726;
      line-height: .95;
    }
    p { line-height: 1.4; color: #f6d6ac; }
    input {
      width: 100%;
      margin: 7px 0;
      padding: 13px;
      border: 2px solid #7d2636;
      background: #160e12;
      color: #ffe8c7;
      font-size: 18px;
      text-align: center;
      text-transform: uppercase;
      font-weight: 900;
    }
    button, a.btn {
      border: 0;
      display: inline-block;
      margin: 7px 5px;
      padding: 13px 16px;
      background: #ffcc5c;
      color: #170c0c;
      font-weight: 1000;
      cursor: pointer;
      text-decoration: none;
      box-shadow: 0 5px 0 #7d2636;
    }
    button:hover, a.btn:hover { transform: translateY(-1px); }
    .hidden { display: none; }
    .small { font-size: 13px; color: #b99b7c; }
    .top {
      position: absolute;
      left: 20px;
      right: 20px;
      top: 18px;
      display: flex;
      justify-content: space-between;
      gap: 10px;
      pointer-events: none;
      font-size: 14px;
    }
    .pill {
      background: rgba(0,0,0,.55);
      border: 1px solid rgba(255,255,255,.16);
      padding: 7px 10px;
      border-radius: 999px;
      color: #ffe8c7;
      font-weight: 900;
    }
    @media(max-width: 720px) {
      .frame { padding: 0; width: 100vw; height: 100vh; }
      canvas { border: 0; }
      .overlay { inset: 0; }
    }
  </style>
</head>
<body>
  <div class="frame">
    <canvas id="game" width="960" height="620"></canvas>
    <div class="top">
      <div class="pill" id="roomPill">Not connected</div>
      <div class="pill" id="scorePill">Score 0 - 0</div>
      <div class="pill" id="weaponPill">1 Pistol</div>
    </div>
    <div class="overlay" id="overlay">
      <div class="panel" id="panel">
        <h1>1v1 ARENA</h1>
        <p>No monsters. Just you and a friend using pistol, shotgun, and rifle.</p>
        <input id="nameInput" maxlength="18" placeholder="Your name" value="Player"/>
        <input id="roomInput" maxlength="5" placeholder="Room code"/>
        <div>
          <button id="createBtn">Create Invite Room</button>
          <button id="joinBtn">Join Room</button>
        </div>
        <p class="small">
          Controls: WASD move, mouse aim, click/space shoot, 1 pistol, 2 shotgun, 3 rifle, Shift sprint, Q/right-click aim.
        </p>
        <p class="small">Host this on Render, then send your friend the invite link or room code.</p>
      </div>
    </div>
  </div>

<script>
(() => {
  "use strict";

  const canvas = document.getElementById("game");
  const ctx = canvas.getContext("2d", { alpha: false });
  ctx.imageSmoothingEnabled = false;

  const overlay = document.getElementById("overlay");
  const panel = document.getElementById("panel");
  const nameInput = document.getElementById("nameInput");
  const roomInput = document.getElementById("roomInput");
  const createBtn = document.getElementById("createBtn");
  const joinBtn = document.getElementById("joinBtn");
  const roomPill = document.getElementById("roomPill");
  const scorePill = document.getElementById("scorePill");
  const weaponPill = document.getElementById("weaponPill");

  const W = canvas.width;
  const H = canvas.height;
  const FOV_NORMAL = Math.PI / 3;
  const FOV_ADS = Math.PI / 4.15;
  const NUM_RAYS = 320;
  const STRIP = W / NUM_RAYS;
  const PROJ_BASE = W / 2;
  const TWO_PI = Math.PI * 2;

  const map = [
    "111111111111111",
    "100000000000001",
    "101110000011101",
    "100010000010001",
    "100010111010001",
    "100000100000001",
    "111010100010111",
    "100010000010001",
    "100000111000001",
    "101110000011101",
    "100000000000001",
    "111111111111111"
  ].map(r => r.split(""));
  const MAP_W = map[0].length;
  const MAP_H = map.length;

  const spawnPoints = [
    { x: 2.5, y: 2.5, a: 0.65 },
    { x: 12.5, y: 9.5, a: Math.PI + 0.65 }
  ];

  const keys = Object.create(null);
  const depths = new Array(NUM_RAYS).fill(99);
  const peers = new Map();
  const particles = [];
  const floatTexts = [];

  let socket = null;
  let selfId = null;
  let roomCode = null;
  let connected = false;
  let gameState = "menu";
  let mouseDown = false;
  let lastTime = performance.now();
  let lastSend = 0;
  let screenShake = 0;
  let flash = 0;

  const player = {
    x: 2.5, y: 2.5, a: 0,
    hp: 100,
    alive: true,
    score: 0,
    weapon: 0,
    lastShot: 0,
    recoil: 0,
    ads: false,
    bob: 0,
    name: "Player"
  };

  const weapons = [
    { name: "PISTOL", damage: 18, pellets: 1, spread: 0.008, cooldown: 260, recoil: 8, auto: false },
    { name: "SHOTGUN", damage: 12, pellets: 8, spread: 0.12, cooldown: 820, recoil: 25, auto: false },
    { name: "RIFLE", damage: 9, pellets: 1, spread: 0.026, cooldown: 85, recoil: 6, auto: true }
  ];

  const audio = {
    ctx: null,
    enabled: true,
    ensure() {
      if (!this.ctx) this.ctx = new (window.AudioContext || window.webkitAudioContext)();
      if (this.ctx.state === "suspended") this.ctx.resume();
      return this.ctx;
    },
    tone(freq, dur, type, vol, bend = 1, delay = 0) {
      if (!this.enabled) return;
      const ac = this.ensure();
      const t = ac.currentTime + delay;
      const osc = ac.createOscillator();
      const g = ac.createGain();
      osc.type = type;
      osc.frequency.setValueAtTime(freq, t);
      if (bend !== 1) osc.frequency.exponentialRampToValueAtTime(Math.max(24, freq * bend), t + dur);
      g.gain.setValueAtTime(0.0001, t);
      g.gain.exponentialRampToValueAtTime(vol, t + 0.004);
      g.gain.exponentialRampToValueAtTime(0.0001, t + dur);
      osc.connect(g); g.connect(ac.destination);
      osc.start(t); osc.stop(t + dur + .03);
    },
    noise(dur, vol, delay = 0, filterFreq = 900) {
      if (!this.enabled) return;
      const ac = this.ensure();
      const t = ac.currentTime + delay;
      const buffer = ac.createBuffer(1, Math.floor(ac.sampleRate * dur), ac.sampleRate);
      const data = buffer.getChannelData(0);
      let held = 0;
      for (let i = 0; i < data.length; i++) {
        if (i % 14 === 0) held = Math.random() * 2 - 1;
        data[i] = held;
      }
      const src = ac.createBufferSource();
      const filter = ac.createBiquadFilter();
      const g = ac.createGain();
      filter.type = "lowpass";
      filter.frequency.setValueAtTime(filterFreq, t);
      g.gain.setValueAtTime(0.0001, t);
      g.gain.exponentialRampToValueAtTime(vol, t + .004);
      g.gain.exponentialRampToValueAtTime(0.0001, t + dur);
      src.buffer = buffer;
      src.connect(filter); filter.connect(g); g.connect(ac.destination);
      src.start(t); src.stop(t + dur + .03);
    },
    play(kind) {
      try {
        if (kind === "pistol") {
          this.tone(560, .045, "square", .16, .42);
          this.tone(145, .085, "square", .18, .34);
          this.noise(.05, .08, 0, 1250);
        } else if (kind === "shotgun") {
          this.tone(88, .20, "square", .25, .25);
          this.tone(175, .12, "sawtooth", .18, .34);
          this.noise(.19, .25, 0, 620);
        } else if (kind === "rifle") {
          this.tone(730, .03, "square", .13, .54);
          this.tone(230, .048, "square", .12, .46);
          this.noise(.03, .08, 0, 1450);
        } else if (kind === "hit") {
          this.tone(500, .05, "triangle", .08, .75);
        } else if (kind === "death") {
          this.tone(90, .22, "sawtooth", .12, .35);
          this.noise(.18, .10, 0, 500);
        } else if (kind === "respawn") {
          this.tone(440, .08, "triangle", .08, 1.4);
          this.tone(660, .08, "square", .06, 1.25, .06);
        }
      } catch {}
    }
  };

  function wsUrl() {
    const proto = location.protocol === "https:" ? "wss:" : "ws:";
    return `${proto}//${location.host}`;
  }

  function connect() {
    if (socket && socket.readyState === WebSocket.OPEN) return socket;
    socket = new WebSocket(wsUrl());

    socket.onopen = () => {
      connected = true;
      roomPill.textContent = "Connected";
    };

    socket.onclose = () => {
      connected = false;
      roomPill.textContent = "Disconnected";
      addFloat("Disconnected", W/2, 90, "#ff7777", true);
    };

    socket.onerror = () => addFloat("Connection error", W/2, 90, "#ff7777", true);

    socket.onmessage = (ev) => {
      let msg;
      try { msg = JSON.parse(ev.data); } catch { return; }
      handleServer(msg);
    };

    return socket;
  }

  function send(msg) {
    if (socket && socket.readyState === WebSocket.OPEN) {
      socket.send(JSON.stringify(msg));
    }
  }

  function handleServer(msg) {
    if (msg.type === "error") {
      showMenu(`<h1>ROOM ERROR</h1><p>${escapeHtml(msg.message)}</p><button onclick="location.reload()">Back</button>`);
      return;
    }

    if (msg.type === "created" || msg.type === "joined") {
      selfId = msg.playerId;
      roomCode = msg.room;
      player.name = nameInput.value.trim() || "Player";
      const index = msg.players.findIndex(p => p.id === selfId);
      setSpawn(index <= 0 ? 0 : 1);
      roomPill.textContent = `Room ${roomCode}`;
      gameState = "playing";
      overlay.classList.add("hidden");
      updatePlayers(msg.players);
      history.replaceState(null, "", `/multiplayer.html?room=${roomCode}`);
      showInvite();
      return;
    }

    if (msg.type === "players") {
      updatePlayers(msg.players);
      return;
    }

    if (msg.type === "peer_state") {
      let p = peers.get(msg.playerId) || { id: msg.playerId, hp: 100, score: 0, alive: true, state: null, name: "Opponent" };
      p.state = msg.state;
      peers.set(msg.playerId, p);
      return;
    }

    if (msg.type === "shot") {
      const p = peers.get(msg.playerId);
      if (p && p.state) {
        makeMuzzle(p.state.x, p.state.y, p.state.a);
        audio.play(msg.weapon === 1 ? "shotgun" : msg.weapon === 2 ? "rifle" : "pistol");
      }
      return;
    }

    if (msg.type === "hurt") {
      updatePlayers(msg.players);
      if (msg.victimId === selfId) {
        screenShake = Math.max(screenShake, 8);
        addFloat("-" + msg.damage, W/2, 110, "#ff7777", true);
        audio.play("hit");
      }
      return;
    }

    if (msg.type === "death") {
      updatePlayers(msg.players);
      audio.play("death");
      if (msg.victimId === selfId) {
        player.alive = false;
        addFloat("YOU GOT FRAGGED", W/2, 120, "#ff7777", true);
      } else if (msg.killerId === selfId) {
        addFloat("FRAG!", W/2, 120, "#ffcc5c", true);
      }
      return;
    }

    if (msg.type === "respawn") {
      const peerCount = Array.from(peers.keys()).length;
      setSpawn(peerCount === 0 ? 0 : 1);
      player.hp = 100;
      player.alive = true;
      audio.play("respawn");
      addFloat("RESPAWNED", W/2, 120, "#9dff9d", true);
      return;
    }

    if (msg.type === "left") {
      updatePlayers(msg.players);
      addFloat("Opponent left", W/2, 90, "#ffcc5c", true);
      return;
    }

    if (msg.type === "reset") {
      updatePlayers(msg.players);
      player.hp = 100;
      player.alive = true;
      setSpawn(0);
    }
  }

  function updatePlayers(list) {
    const seen = new Set();
    for (const p of list) {
      seen.add(p.id);
      if (p.id === selfId) {
        player.hp = p.hp;
        player.score = p.score;
        player.alive = p.alive;
      } else {
        const old = peers.get(p.id) || {};
        peers.set(p.id, { ...old, ...p });
      }
    }
    for (const id of peers.keys()) {
      if (!seen.has(id)) peers.delete(id);
    }
    updateScore();
  }

  function showInvite() {
    const url = `${location.origin}/multiplayer.html?room=${roomCode}`;
    addFloat(`ROOM ${roomCode}`, W/2, 80, "#ffcc5c", true);
    setTimeout(() => {
      if (gameState !== "playing") return;
      overlay.classList.remove("hidden");
      panel.innerHTML = `
        <h1>ROOM ${roomCode}</h1>
        <p>Send this code to your friend, or send the invite link.</p>
        <input value="${url}" readonly onclick="this.select()"/>
        <button id="copyBtn">Copy Invite Link</button>
        <button id="playBtn">Start Playing</button>
        <p class="small">Your friend opens the link and joins the same room.</p>
      `;
      document.getElementById("copyBtn").onclick = async () => {
        try { await navigator.clipboard.writeText(url); } catch {}
      };
      document.getElementById("playBtn").onclick = () => {
        overlay.classList.add("hidden");
        canvas.requestPointerLock?.();
      };
    }, 250);
  }

  function showMenu(html) {
    overlay.classList.remove("hidden");
    panel.innerHTML = html;
  }

  function escapeHtml(s) {
    return String(s).replace(/[&<>"']/g, m => ({ "&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#39;" }[m]));
  }

  function createRoom() {
    audio.ensure();
    connect();
    setTimeout(() => send({ type: "create", name: nameInput.value.trim() || "Player" }), 80);
  }

  function joinRoom() {
    audio.ensure();
    const room = (roomInput.value || new URLSearchParams(location.search).get("room") || "").trim().toUpperCase();
    if (!room) {
      addFloat("Enter a room code", W/2, 90, "#ff7777", true);
      return;
    }
    connect();
    setTimeout(() => send({ type: "join", room, name: nameInput.value.trim() || "Player" }), 80);
  }

  createBtn.onclick = createRoom;
  joinBtn.onclick = joinRoom;

  const urlRoom = new URLSearchParams(location.search).get("room");
  if (urlRoom) roomInput.value = urlRoom.toUpperCase();

  function setSpawn(i) {
    const s = spawnPoints[i % spawnPoints.length];
    player.x = s.x; player.y = s.y; player.a = s.a;
  }

  function normalizeAngle(a) { a %= TWO_PI; return a < 0 ? a + TWO_PI : a; }
  function angleDiff(a, b) {
    let d = normalizeAngle(a) - normalizeAngle(b);
    if (d > Math.PI) d -= TWO_PI;
    if (d < -Math.PI) d += TWO_PI;
    return d;
  }
  function clamp(v, min, max) { return Math.max(min, Math.min(max, v)); }
  function dist(ax, ay, bx, by) { return Math.hypot(ax - bx, ay - by); }
  function isWall(x, y) {
    const mx = Math.floor(x), my = Math.floor(y);
    if (mx < 0 || my < 0 || mx >= MAP_W || my >= MAP_H) return true;
    return map[my][mx] === "1";
  }
  function canMoveTo(x, y, r=.21) {
    return !isWall(x-r, y-r) && !isWall(x+r, y-r) && !isWall(x-r, y+r) && !isWall(x+r, y+r);
  }
  function lineOfSight(x1, y1, x2, y2) {
    const d = dist(x1, y1, x2, y2);
    const steps = Math.max(1, Math.floor(d * 14));
    for (let i = 1; i < steps; i++) {
      const t = i / steps;
      if (isWall(x1 + (x2-x1)*t, y1 + (y2-y1)*t)) return false;
    }
    return true;
  }

  function currentFov() { return player.ads ? FOV_ADS : FOV_NORMAL; }
  function currentProj() { return PROJ_BASE / Math.tan(currentFov() / 2); }

  function castRay(angle, maxDist=28) {
    angle = normalizeAngle(angle);
    const sin = Math.sin(angle), cos = Math.cos(angle);
    let mapX = Math.floor(player.x), mapY = Math.floor(player.y);
    const deltaX = Math.abs(1 / (cos || .00001));
    const deltaY = Math.abs(1 / (sin || .00001));
    let stepX, stepY, sideX, sideY;

    if (cos < 0) { stepX = -1; sideX = (player.x - mapX) * deltaX; }
    else { stepX = 1; sideX = (mapX + 1 - player.x) * deltaX; }
    if (sin < 0) { stepY = -1; sideY = (player.y - mapY) * deltaY; }
    else { stepY = 1; sideY = (mapY + 1 - player.y) * deltaY; }

    let side = 0;
    for (let i = 0; i < 100; i++) {
      if (sideX < sideY) { sideX += deltaX; mapX += stepX; side = 0; }
      else { sideY += deltaY; mapY += stepY; side = 1; }

      if (mapX < 0 || mapY < 0 || mapX >= MAP_W || mapY >= MAP_H || map[mapY][mapX] === "1") {
        const d = side === 0
          ? (mapX - player.x + (1 - stepX) / 2) / (cos || .00001)
          : (mapY - player.y + (1 - stepY) / 2) / (sin || .00001);
        return { dist: Math.abs(d), side, hitX: player.x + cos * Math.abs(d), hitY: player.y + sin * Math.abs(d) };
      }
      if (Math.hypot(mapX-player.x, mapY-player.y) > maxDist) break;
    }
    return { dist: maxDist, side: 0, hitX: player.x + cos * maxDist, hitY: player.y + sin * maxDist };
  }

  function update(dt, now) {
    if (gameState !== "playing") {
      updateFx(dt);
      return;
    }

    player.ads = keys["KeyQ"] || keys["MouseRight"];
    const speed = (keys["ShiftLeft"] || keys["ShiftRight"] ? .0047 : .0035) * (player.ads ? .62 : 1) * dt;

    if (keys["ArrowLeft"]) player.a -= .0025 * dt;
    if (keys["ArrowRight"]) player.a += .0025 * dt;

    if (player.alive) {
      const forward = (keys["KeyW"] ? 1 : 0) - (keys["KeyS"] ? 1 : 0);
      const strafe = (keys["KeyD"] ? 1 : 0) - (keys["KeyA"] ? 1 : 0);
      if (forward || strafe) {
        const ca = Math.cos(player.a), sa = Math.sin(player.a);
        let mx = (ca * forward + Math.cos(player.a + Math.PI/2) * strafe) * speed;
        let my = (sa * forward + Math.sin(player.a + Math.PI/2) * strafe) * speed;
        const mag = Math.hypot(mx, my);
        if (mag > speed) { mx = mx / mag * speed; my = my / mag * speed; }
        if (canMoveTo(player.x + mx, player.y)) player.x += mx;
        if (canMoveTo(player.x, player.y + my)) player.y += my;
        player.bob += dt * .012;
      } else {
        player.bob += dt * .003;
      }
    }

    if (mouseDown && weapons[player.weapon].auto) tryFire(now);

    player.recoil *= Math.pow(.006, dt/1000);
    flash = Math.max(0, flash - dt * .08);
    screenShake = Math.max(0, screenShake - dt * .02);

    if (now - lastSend > 50) {
      lastSend = now;
      send({
        type: "state",
        state: {
          x: player.x, y: player.y, a: player.a,
          hp: player.hp, alive: player.alive,
          weapon: player.weapon, ads: player.ads, name: player.name
        }
      });
    }

    updateFx(dt);
  }

  function tryFire(now=performance.now()) {
    if (gameState !== "playing" || !player.alive) return;
    const w = weapons[player.weapon];
    if (now - player.lastShot < w.cooldown) return;
    player.lastShot = now;
    player.recoil = Math.max(player.recoil, w.recoil);
    flash = 12;
    screenShake = Math.max(screenShake, player.weapon === 1 ? 5 : 2);

    audio.play(player.weapon === 0 ? "pistol" : player.weapon === 1 ? "shotgun" : "rifle");
    send({ type: "shot", weapon: player.weapon, x: player.x, y: player.y, a: player.a });
    makeMuzzle(player.x, player.y, player.a);

    let totalHit = new Map();
    for (let i = 0; i < w.pellets; i++) {
      const spread = (Math.random() - .5) * w.spread * (player.ads ? .48 : 1);
      const hit = findPlayerHit(player.a + spread);
      if (hit) totalHit.set(hit.id, (totalHit.get(hit.id) || 0) + w.damage);
    }
    for (const [targetId, damage] of totalHit.entries()) {
      send({ type: "hit", targetId, damage, weapon: player.weapon });
    }
  }

  function findPlayerHit(angle) {
    const ray = castRay(angle, 18);
    let best = null;
    let bestDist = ray.dist;
    for (const [id, p] of peers.entries()) {
      if (!p.alive || !p.state) continue;
      const dx = p.state.x - player.x, dy = p.state.y - player.y;
      const along = dx * Math.cos(angle) + dy * Math.sin(angle);
      if (along <= 0 || along > bestDist) continue;
      const perp = Math.abs(-Math.sin(angle) * dx + Math.cos(angle) * dy);
      if (perp <= .31 && lineOfSight(player.x, player.y, p.state.x, p.state.y)) {
        best = p; bestDist = along;
      }
    }
    return best;
  }

  function makeMuzzle(x, y, a) {
    for (let i = 0; i < 10; i++) {
      particles.push({
        x: x + Math.cos(a) * .4,
        y: y + Math.sin(a) * .4,
        vx: Math.cos(a + (Math.random()-.5)*.35) * (0.4 + Math.random()*0.7),
        vy: Math.sin(a + (Math.random()-.5)*.35) * (0.4 + Math.random()*0.7),
        z: .3 + Math.random()*.25,
        life: 120 + Math.random()*80,
        max: 200,
        color: Math.random() < .6 ? "#ffdc75" : "#ff7b3c",
        size: 3 + Math.random()*5
      });
    }
  }

  function updateFx(dt) {
    for (const p of particles) {
      p.x += p.vx * dt * .001;
      p.y += p.vy * dt * .001;
      p.life -= dt;
    }
    for (const f of floatTexts) {
      f.y += f.vy * dt * .06;
      f.life -= dt;
    }
    for (let i = particles.length - 1; i >= 0; i--) if (particles[i].life <= 0) particles.splice(i, 1);
    for (let i = floatTexts.length - 1; i >= 0; i--) if (floatTexts[i].life <= 0) floatTexts.splice(i, 1);
  }

  function render() {
    ctx.save();
    if (screenShake > 0) ctx.translate((Math.random()-.5)*screenShake, (Math.random()-.5)*screenShake);
    draw3D();
    drawSprites();
    drawWeapon();
    drawHUD();
    ctx.restore();
  }

  function draw3D() {
    const sky = ctx.createLinearGradient(0,0,0,H/2);
    sky.addColorStop(0, "#12141b");
    sky.addColorStop(1, "#33313a");
    ctx.fillStyle = sky;
    ctx.fillRect(0,0,W,H/2);

    for (let y = H/2; y < H; y += 4) {
      const shade = Math.floor(20 + (y/H)*52);
      ctx.fillStyle = `rgb(${shade},${shade+2},${shade+5})`;
      ctx.fillRect(0,y,W,4);
    }

    const fov = currentFov();
    const proj = currentProj();
    const start = player.a - fov/2;
    for (let i = 0; i < NUM_RAYS; i++) {
      const a = start + (i / NUM_RAYS) * fov;
      const hit = castRay(a);
      const corrected = hit.dist * Math.cos(angleDiff(a, player.a));
      depths[i] = corrected;
      const wallH = Math.min(H * 1.8, proj / corrected);
      const x = i * STRIP;
      const y = H/2 - wallH/2;
      const far = clamp(corrected / 12, 0, 1);
      const base = hit.side ? 82 : 116;
      const flick = (Math.floor((hit.hitX + hit.hitY) * 6) % 2) * 10;
      const r = Math.floor(base + flick - far * 65);
      const g = Math.floor(base + 6 + flick * .4 - far * 62);
      const b = Math.floor(base + 12 + flick * .35 - far * 58);
      ctx.fillStyle = `rgb(${r},${g},${b})`;
      ctx.fillRect(x, y, Math.ceil(STRIP)+1, wallH);
      if (Math.floor((hit.hitX + hit.hitY) * 9) % 7 === 0) {
        ctx.fillStyle = `rgba(8,10,12,${.18 + far*.2})`;
        ctx.fillRect(x,y,Math.ceil(STRIP)+1,wallH);
      }
      ctx.fillStyle = `rgba(0,0,0,${far * .34})`;
      ctx.fillRect(x,y,Math.ceil(STRIP)+1,wallH);
    }
  }

  function drawSprites() {
    const drawables = [];

    for (const [id, p] of peers.entries()) {
      if (p.state && p.alive) drawables.push({ kind: "player", p, dist: dist(player.x, player.y, p.state.x, p.state.y) });
    }
    for (const p of particles) drawables.push({ kind: "particle", p, dist: dist(player.x, player.y, p.x, p.y) });

    drawables.sort((a,b) => b.dist - a.dist);

    for (const d of drawables) {
      const it = d.kind === "player" ? d.p.state : d.p;
      const dx = it.x - player.x, dy = it.y - player.y;
      const angle = Math.atan2(dy, dx);
      const da = angleDiff(angle, player.a);
      const fov = currentFov();
      if (Math.abs(da) > fov * .65) continue;
      const corrected = d.dist * Math.cos(da);
      if (corrected <= .025) continue;
      if (d.kind === "player" && !lineOfSight(player.x, player.y, it.x, it.y)) continue;

      const proj = currentProj();
      const sx = W/2 + Math.tan(da) * proj;
      const baseSize = proj / corrected;
      const rayIndex = Math.floor(((da + fov/2) / fov) * NUM_RAYS);
      if (rayIndex >= 0 && rayIndex < NUM_RAYS && corrected > depths[rayIndex] + .15) continue;

      if (d.kind === "player") drawPlayerSprite(d.p, sx, H/2, baseSize, corrected);
      else drawParticleSprite(d.p, sx, H/2, baseSize, corrected);
    }
  }

  function drawPlayerSprite(p, sx, centerY, baseSize, distance) {
    const size = clamp(baseSize * .82, 22, 430);
    const x = sx - size/2;
    const y = Math.min(centerY + baseSize*.28, H-80) - size;
    const s = size / 16;
    ctx.save();
    ctx.globalAlpha = clamp(1 - distance / 18, .28, 1);

    ctx.fillStyle = "rgba(0,0,0,.45)";
    ctx.fillRect(x + size*.15, y + size*.92, size*.7, size*.12);

    function block(cx, cy, cw, ch, color) {
      ctx.fillStyle = color;
      ctx.fillRect(Math.round(x + cx*s), Math.round(y + cy*s), Math.ceil(cw*s), Math.ceil(ch*s));
    }

    block(5, 1, 6, 4, "#d18a55");
    block(4, 5, 8, 7, "#334b8f");
    block(5, 3, 2, 1.5, "#111");
    block(9, 3, 2, 1.5, "#111");
    block(3, 7, 3, 5, "#25396e");
    block(10, 7, 3, 5, "#25396e");
    block(5, 12, 2, 4, "#1b2446");
    block(9, 12, 2, 4, "#1b2446");
    block(11, 7, 5, 1.5, "#34383e");

    // Name and health bar.
    const bw = size * .82;
    ctx.fillStyle = "rgba(0,0,0,.75)";
    ctx.fillRect(sx - bw/2, y - 20, bw, 7);
    ctx.fillStyle = "#66ff8c";
    ctx.fillRect(sx - bw/2, y - 20, bw * clamp(p.hp/100, 0, 1), 7);
    ctx.textAlign = "center";
    ctx.font = `${Math.max(10, Math.min(18, size*.08))}px monospace`;
    ctx.fillStyle = "#fff0c9";
    ctx.fillText(p.name || "Opponent", sx, y - 25);
    ctx.restore();
  }

  function drawParticleSprite(p, sx, centerY, baseSize, distance) {
    const size = clamp((p.size || 3) * (currentProj() / distance) * .015, 1, 18);
    const y = centerY + baseSize * (0.35 - (p.z || 0) * .7);
    ctx.save();
    ctx.globalAlpha = clamp(p.life / p.max, 0, 1);
    ctx.fillStyle = p.color;
    ctx.fillRect(Math.round(sx - size/2), Math.round(y - size/2), Math.ceil(size), Math.ceil(size));
    ctx.restore();
  }

  function drawWeapon() {
    const w = weapons[player.weapon];
    const bob = Math.sin(player.bob) * (player.ads ? 2 : 6);
    const recoil = player.recoil;
    const baseX = W/2;
    const baseY = H - (player.ads ? 125 : 90) + recoil + Math.abs(bob);

    if (flash > 0) {
      ctx.save();
      ctx.globalAlpha = clamp(flash / 12, 0, 1);
      ctx.fillStyle = "#fff0a3";
      ctx.beginPath();
      ctx.moveTo(W/2 - 28, H/2 + 20);
      ctx.lineTo(W/2, H/2 - 55);
      ctx.lineTo(W/2 + 32, H/2 + 20);
      ctx.closePath();
      ctx.fill();
      ctx.restore();
    }

    ctx.save();
    if (player.weapon === 0) drawPistol(baseX, baseY, player.ads);
    else if (player.weapon === 1) drawShotgun(baseX, baseY, player.ads);
    else drawRifle(baseX, baseY, player.ads);
    ctx.restore();

    // Crosshair
    ctx.save();
    ctx.globalAlpha = player.ads ? .9 : .75;
    ctx.fillStyle = "#fff0c9";
    const spread = player.ads ? 9 : 14 + player.recoil * .15;
    ctx.fillRect(W/2 - spread, H/2, 8, 2);
    ctx.fillRect(W/2 + spread - 8, H/2, 8, 2);
    ctx.fillRect(W/2, H/2 - spread, 2, 8);
    ctx.fillRect(W/2, H/2 + spread - 8, 2, 8);
    ctx.restore();
  }

  function drawPistol(x, y, ads) {
    ctx.fillStyle = "#0d0d10";
    ctx.fillRect(x - 28, y - 46, 56, 70);
    ctx.fillStyle = "#4c5159";
    ctx.fillRect(x - 20, y - 72, 40, 46);
    ctx.fillStyle = "#858c94";
    ctx.fillRect(x - 16, y - 76, 32, 12);
    ctx.fillStyle = "#8c6c48";
    ctx.fillRect(x - 15, y + 16, 30, 46);
  }

  function drawShotgun(x, y, ads) {
    // Original simple shotgun look — no pump/cock animation.
    ctx.fillStyle = "#171114";
    ctx.fillRect(x - 42, y - 42, 84, 48);
    ctx.fillStyle = "#604126";
    ctx.fillRect(x - 58, y - 8, 116, 32);
    ctx.fillStyle = "#2c3034";
    ctx.fillRect(x - 34, y - 82, 20, 82);
    ctx.fillRect(x + 14, y - 82, 20, 82);
    ctx.fillStyle = "#7c848c";
    ctx.fillRect(x - 30, y - 88, 12, 12);
    ctx.fillRect(x + 18, y - 88, 12, 12);
    ctx.fillStyle = "#3b2419";
    ctx.fillRect(x - 72, y + 22, 144, 62);
  }

  function drawRifle(x, y, ads) {
    ctx.fillStyle = "#101113";
    ctx.fillRect(x - 76, y - 36, 152, 34);
    ctx.fillStyle = "#3d4248";
    ctx.fillRect(x - 46, y - 72, 92, 44);
    ctx.fillStyle = "#808891";
    ctx.fillRect(x - 32, y - 84, 64, 12);
    ctx.fillStyle = "#23262a";
    ctx.fillRect(x - 12, y - 64, 24, 34);
    ctx.fillStyle = "#5b3c23";
    ctx.fillRect(x - 88, y, 176, 38);
    ctx.fillStyle = "#241a15";
    ctx.fillRect(x - 64, y + 38, 128, 54);
  }

  function drawHUD() {
    ctx.fillStyle = "#171014";
    ctx.fillRect(0, H-78, W, 78);
    ctx.fillStyle = "#3b2026";
    ctx.fillRect(0, H-78, W, 5);

    ctx.font = "900 22px monospace";
    ctx.textBaseline = "top";
    drawBox(18, H-61, 150, "HEALTH", player.hp, player.hp <= 25 ? "#ff5555" : "#66ff8c");
    drawBox(188, H-61, 190, "MODE", player.ads ? "ADS" : "HIP", "#ffda76");
    drawBox(398, H-61, 210, "WEAPON", `${player.weapon+1} ${weapons[player.weapon].name}`, "#fff0c9");

    for (const f of floatTexts) {
      ctx.save();
      ctx.globalAlpha = clamp(f.life / f.max, 0, 1);
      ctx.textAlign = "center";
      ctx.font = f.big ? "900 24px monospace" : "900 18px monospace";
      ctx.fillStyle = "#000";
      ctx.fillText(f.text, f.x + 2, f.y + 2);
      ctx.fillStyle = f.color;
      ctx.fillText(f.text, f.x, f.y);
      ctx.restore();
    }

    if (!player.alive) {
      ctx.save();
      ctx.fillStyle = "rgba(120,0,0,.35)";
      ctx.fillRect(0,0,W,H);
      ctx.textAlign = "center";
      ctx.font = "900 42px monospace";
      ctx.fillStyle = "#ff7777";
      ctx.fillText("RESPAWNING...", W/2, H/2 - 30);
      ctx.restore();
    }

    weaponPill.textContent = `${player.weapon + 1} ${weapons[player.weapon].name}`;
  }

  function drawBox(x, y, w, label, value, color) {
    ctx.fillStyle = "#0e0b0e";
    ctx.fillRect(x,y,w,45);
    ctx.strokeStyle = "#4d3332";
    ctx.strokeRect(x,y,w,45);
    ctx.fillStyle = "#d7b46a";
    ctx.font = "900 15px monospace";
    ctx.fillText(label, x+10, y+5);
    ctx.fillStyle = color;
    ctx.font = "900 25px monospace";
    ctx.fillText(String(value), x+10, y+22);
  }

  function addFloat(text, x, y, color="#fff", big=false) {
    floatTexts.push({ text, x, y, color, big, vy: big ? -.35 : -.55, life: big ? 1400 : 800, max: big ? 1400 : 800 });
  }

  function updateScore() {
    const opponent = Array.from(peers.values())[0];
    const enemyScore = opponent ? opponent.score || 0 : 0;
    scorePill.textContent = `Score ${player.score || 0} - ${enemyScore}`;
  }

  function loop(now) {
    const dt = Math.min(50, now - lastTime || 16);
    lastTime = now;
    update(dt, now);
    render();
    requestAnimationFrame(loop);
  }

  function setKey(e, val) {
    keys[e.code] = val;
    const k = (e.key || "").toLowerCase();
    if (k === "w") keys["KeyW"] = val;
    if (k === "a") keys["KeyA"] = val;
    if (k === "s") keys["KeyS"] = val;
    if (k === "d") keys["KeyD"] = val;
    if (k === "q") keys["KeyQ"] = val;
    if (k === "shift") { keys["ShiftLeft"] = val; keys["ShiftRight"] = val; }
  }

  window.addEventListener("keydown", e => {
    setKey(e, true);
    const k = (e.key || "").toLowerCase();
    if (e.code === "Space" || k === " ") { e.preventDefault(); tryFire(); }
    if (k === "1") player.weapon = 0;
    if (k === "2") player.weapon = 1;
    if (k === "3") player.weapon = 2;
    if (["KeyW","KeyA","KeyS","KeyD","Space"].includes(e.code)) e.preventDefault();
  });
  window.addEventListener("keyup", e => setKey(e, false));

  canvas.addEventListener("mousedown", e => {
    if (gameState !== "playing") return;
    if (e.button === 2) { keys["MouseRight"] = true; e.preventDefault(); return; }
    mouseDown = true;
    canvas.requestPointerLock?.();
    tryFire();
  });
  window.addEventListener("mouseup", e => {
    if (e.button === 2) keys["MouseRight"] = false;
    mouseDown = false;
  });
  canvas.addEventListener("contextmenu", e => e.preventDefault());

  document.addEventListener("mousemove", e => {
    if (document.pointerLockElement === canvas && gameState === "playing") {
      player.a = normalizeAngle(player.a + e.movementX * .0024);
    }
  });

  requestAnimationFrame(loop);
})();
</script>
</body>
</html>